---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Manifesto from '../components/Manifesto.astro';
import Ticker from '../components/Ticker.astro';
import Services from '../components/Services.astro';
import Work from '../components/Work.astro';
import Founder from '../components/Founder.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

// structured data: what search engines show for "psychedelic industry
// software" queries. legalName is public record (Utah DBA, 2026-07-17).
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'elliodelics',
  legalName: 'Elliotec Software LLC',
  url: 'https://elliodelics.com',
  logo: 'https://elliodelics.com/favicon.svg',
  image: 'https://elliodelics.com/og.png',
  email: 'mike@elliodelics.com',
  description:
    'Software engineering for the psychedelic industry. Due-diligence readiness, data protection, AI governance, product engineering, and fractional engineering leadership.',
  founder: {
    '@type': 'Person',
    name: 'Mike Elliott',
    jobTitle: 'Founder & Principal Engineer',
    url: 'https://elliotec.com',
  },
};
---

<Base
  title="elliodelics · code and compliance for the psychedelic industry"
  description="When the hard questions about your data arrive, the answers already exist. Make sure they're the right ones."
>
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} is:inline />
  <main>
    <Hero />
    <Manifesto />
    <Ticker />
    <Services />
    <Work />
    <Founder />
    <Contact />
  </main>
  <Footer />
</Base>
