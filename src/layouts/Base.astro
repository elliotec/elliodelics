---
import '@fontsource/bricolage-grotesque/800.css';
import '@fontsource/museomoderno/700.css'; // the logo face
import museoWoff from '@fontsource/museomoderno/files/museomoderno-latin-700-normal.woff2?url';
import '@fontsource-variable/source-serif-4/wght.css';
import '@fontsource/jetbrains-mono/400.css';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/* GitHub Pages can't set response headers, so CSP rides in a meta tag.
        'unsafe-inline' is required by Astro's inlined scripts/styles; the
        policy still pins every fetchable resource to this origin. Note
        frame-ancestors can't be declared via meta — header-only. */}
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self'; font-src 'self'; object-src 'none'; base-uri 'self'; form-action 'none'"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#00300f" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={new URL(Astro.url.pathname, Astro.site)} />
    <meta property="og:image" content={new URL('/og.png', Astro.site)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="elliodelics, code and compliance for the psychedelic industry, on a deep green field of interference rings" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preload" href={museoWoff} as="font" type="font/woff2" crossorigin />
    {/* the logo face must be ready at first paint, or the wordmark flashes
        its Bricolage fallback on every navigation */}
    <script>
      document.documentElement.classList.add('js');
    </script>
  </head>
  <body>
    <slot />
    <script>
      // the page never hides content — what animates is the drawing
      // itself. The observer flips .draw containers to .in as they
      // arrive; every draw's resting state is the finished artwork
      // (from-states live in the keyframes), so print, crawlers, and
      // inspectors always see the completed page.
      // The positive rootMargin fires BEFORE the element enters the
      // viewport: the resting state is the finished drawing, so a trigger
      // after visibility would flash the finished art, blank it, and
      // redraw — armed offscreen, it only ever appears mid-draw.
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              entry.target.classList.add('in');
              observer.unobserve(entry.target);
            }
          }
        },
        { rootMargin: '0px 0px 18% 0px' }
      );
      document.querySelectorAll('.draw').forEach((el) => observer.observe(el));
    </script>
  </body>
</html>
