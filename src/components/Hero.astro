---
const email = 'mike@mindscapecollective.org';
---

<section class="hero" aria-label="Introduction">
  <canvas class="hero-field" aria-hidden="true"></canvas>

  <header class="hero-top container">
    <a class="wordmark brand" href="/">Elliodelics</a>
    <a class="mono top-mail" href={`mailto:${email}`}>{email}</a>
  </header>

  <div class="hero-core container">
    <h1 class="display hero-title">
      <span class="line"><span class="line-inner">Software</span></span>
      <span class="line"><span class="line-inner">for the</span></span>
      <span class="line"><span class="line-inner">psychedelic</span></span>
      <span class="line"><span class="line-inner">industry<span class="dot">.</span></span></span>
    </h1>
    <p class="hero-sub">
      Elliodelics is a software engineering studio for clinics, retreats,
      researchers, and the companies building around them. Somebody has
      to stay grounded.
    </p>
  </div>

  <div class="hero-cues">
    <a class="mono hero-cue" href="#manifesto">begin descent ↓</a>
    <a class="mono hero-cue" href="#contact">skip to contact ↘</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: clip;
  }

  .hero-field {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: var(--z-canvas);
  }

  .hero-top {
    position: relative;
    z-index: var(--z-header);
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    padding-block: 1.6rem;
  }

  .brand {
    font-size: 1.3rem;
    text-decoration: none;
  }

  .top-mail {
    color: var(--ink-dim);
    text-decoration-color: var(--ink-faint);
  }
  .top-mail:hover { color: var(--acid); }

  @media (max-width: 40rem) {
    .top-mail { display: none; } /* the contact section carries the address */
  }

  .hero-core {
    position: relative;
    z-index: var(--z-content);
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: 3rem;
  }

  .hero-title {
    font-size: var(--text-hero);
    margin: 0;
  }

  .line {
    display: block;
    overflow: clip;
    padding-block: 0.04em; /* keep descenders unclipped */
  }

  .line-inner {
    display: inline-block;
  }

  .dot { color: var(--acid); }

  .hero-sub {
    max-width: var(--measure);
    margin-block: 2.2rem 0;
    font-size: var(--text-lg);
    line-height: 1.4;
    color: var(--ink-dim);
  }

  .hero-cues {
    position: relative;
    z-index: var(--z-content);
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 2.2rem;
    margin: 0 var(--gutter) 1.6rem;
  }

  .hero-cue {
    color: var(--acid);
    text-decoration: none;
  }
  .hero-cue:hover { text-decoration: underline; }

  /* -- entrance choreography (JS-gated; page is fine without) -- */
  html.js .line-inner {
    translate: 0 110%;
    animation: rise 1s var(--ease-expo) forwards;
  }
  html.js .line:nth-child(1) .line-inner { animation-delay: 0.10s; }
  html.js .line:nth-child(2) .line-inner { animation-delay: 0.19s; }
  html.js .line:nth-child(3) .line-inner { animation-delay: 0.28s; }
  html.js .line:nth-child(4) .line-inner { animation-delay: 0.37s; }

  html.js .hero-sub,
  html.js .hero-cues,
  html.js .hero-top {
    opacity: 0;
    animation: appear 1.1s var(--ease-out) 0.75s forwards;
  }
  html.js .hero-top { animation-delay: 0.55s; }

  @keyframes rise {
    to { translate: 0 0; }
  }
  @keyframes appear {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    html.js .line-inner { translate: 0 0; animation: none; }
    html.js .hero-sub,
    html.js .hero-cues,
    html.js .hero-top { opacity: 1; animation: none; }
  }
</style>

<script>
  // Interference field: concentric rings from drifting sources create a
  // slow moiré — closed-eye geometry, drawn like a schematic.
  // Rendering notes: no hard clears — each frame washes the canvas with a
  // translucent pass of the page green, so strokes decay like phosphor
  // persistence (hides temporal aliasing, leaves soft trails). The acid
  // highlight is a continuous expanding pulse, never an indexed ring that
  // would pop on phase wrap.
  const canvas = document.querySelector<HTMLCanvasElement>('.hero-field')!;
  const ctx = canvas.getContext('2d')!;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)');

  // Trails multiply brightness: steady-state stroke intensity ≈ line alpha
  // divided by fade alpha. Tune the pair together, not separately.
  const BG = 'oklch(0.29 0.09 152)'; // must match --void
  const FADE = 'oklch(0.29 0.09 152 / 0.35)';
  const LINE = 'oklch(0.78 0.095 305 / 0.06)'; // pointer rings
  const RING_LINE = 'oklch(0.78 0.095 305 / 0.05)'; // the interference field
  const STAMP = 'oklch(0.78 0.095 305 / 0.24)'; // laid-down geometry — brighter, it stays
  const RIPPLE = 'oklch(0.78 0.095 305)'; // solid; alpha applied per-ring
  const PULSE = 'oklch(0.92 0.21 113)';
  const TAU = Math.PI * 2;
  const GAP = 34; // interference ring spacing
  const STAMP_R = 30; // Flower-of-Life circle radius = lattice spacing
  const BRUSH = STAMP_R * 1.55; // stamp the whole neighbourhood — petals, not a line
  const STAMP_CAP = 300; // beyond this the oldest start dissolving immediately
  const STAMP_LIFE = 12000; // ms of growth before a circle starts to dissolve
  const STAMP_FADE = 2500; // ms to dissolve

  let w = 0, h = 0, dpr = 1;
  let running = false;
  let rafId = 0;
  let lastT = 0;

  const pointer = { x: -1, y: -1, tx: -1, ty: -1, active: false };

  // the interference field — three drifting ring emitters
  const ringSources = [
    { ax: 0.22, ay: 0.3, rx: 0.16, ry: 0.12, sx: 0.000041, sy: 0.000053, p: 0 },
    { ax: 0.78, ay: 0.42, rx: 0.14, ry: 0.16, sx: 0.000047, sy: 0.000037, p: 2.1 },
    { ax: 0.5, ay: 0.85, rx: 0.18, ry: 0.1, sx: 0.000035, sy: 0.000049, p: 4.2 },
  ];

  function drawRings(cx: number, cy: number, shift: number, color = RING_LINE) {
    const maxR = maxRadius() * 0.72;
    const offset = ((shift % GAP) + GAP) % GAP;
    ctx.strokeStyle = color;
    ctx.lineWidth = 1;
    for (let r = offset || 0.001; r < maxR; r += GAP) {
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, TAU);
      ctx.stroke();
    }
  }

  // -- Flower-of-Life stamping ------------------------------------------
  // The pointer lays circles onto a fixed triangular lattice with spacing =
  // radius, so every circle passes through its neighbours' centers — the
  // classic construction. Stamped circles bloom in and STAY.
  const stamps = new Map<string, { x: number; y: number; born: number; die: number }>();
  const ROW_H = STAMP_R * (Math.sqrt(3) / 2);

  function stampAt(px: number, py: number, t: number) {
    const row = Math.round(py / ROW_H);
    for (let dr = -2; dr <= 2; dr++) {
      const r = row + dr;
      const xOff = (r % 2 ? 0.5 : 0) * STAMP_R;
      const col = Math.round((px - xOff) / STAMP_R);
      for (let dc = -2; dc <= 2; dc++) {
        const c = col + dc;
        const x = c * STAMP_R + xOff;
        const y = r * ROW_H;
        if (Math.hypot(x - px, y - py) > BRUSH) continue;
        const key = r + ',' + c;
        if (stamps.has(key)) continue;
        stamps.set(key, { x, y, born: t, die: 0 });
        if (stamps.size > STAMP_CAP) {
          // over budget: start dissolving the oldest still-living circle now
          for (const s of stamps.values()) {
            if (!s.die) { s.die = t; break; }
          }
        }
      }
    }
  }

  function drawStamps(t: number) {
    const RIPPLE_GAP = STAMP_R * 0.55;
    const RIPPLE_MAX = STAMP_R * 2.4; // ripples stay local to their circle
    ctx.lineWidth = 1;
    stamps.forEach((s, key) => {
      const age = t - s.born;
      // lifecycle: grow for STAMP_LIFE, then dissolve and free the slot
      if (!s.die && age > STAMP_LIFE) s.die = t;
      let fade = 1;
      if (s.die) {
        fade = 1 - (t - s.die) / STAMP_FADE;
        if (fade <= 0) {
          stamps.delete(key);
          return;
        }
      }
      const k = Math.min(age / 700, 1);
      const ease = 1 - Math.pow(1 - k, 4); // bloom: ease-out-quart
      // every circle keeps growing after its bloom: 2px/s toward a 2.6× cap,
      // so painted regions thicken into mandala overlap
      const base =
        STAMP_R * ease + Math.min(Math.max(age - 700, 0) * 0.002, STAMP_R * 1.6);
      ctx.strokeStyle = STAMP;
      ctx.globalAlpha = (0.35 + 0.65 * ease) * fade;
      ctx.beginPath();
      ctx.arc(s.x, s.y, base, 0, TAU);
      ctx.stroke();
      if (age < 300) {
        // acid flash at birth
        ctx.strokeStyle = PULSE;
        ctx.globalAlpha = 0.4 * (1 - age / 300);
        ctx.beginPath();
        ctx.arc(s.x, s.y, base, 0, TAU);
        ctx.stroke();
        return;
      }
      // ripples ride the growing edge, fading as they travel
      const span = RIPPLE_MAX - STAMP_R;
      const shift = (age * 0.014) % RIPPLE_GAP;
      ctx.strokeStyle = RIPPLE;
      for (let r = base + shift; r < base + span; r += RIPPLE_GAP) {
        ctx.globalAlpha = 0.2 * (1 - (r - base) / span) * fade;
        ctx.beginPath();
        ctx.arc(s.x, s.y, r, 0, TAU);
        ctx.stroke();
      }
    });
    ctx.globalAlpha = 1;
  }

  function resize() {
    dpr = Math.min(window.devicePixelRatio || 1, 1.75);
    w = canvas.clientWidth;
    h = canvas.clientHeight;
    canvas.width = Math.round(w * dpr);
    canvas.height = Math.round(h * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.fillStyle = BG;
    ctx.fillRect(0, 0, w, h);
    if (!running) draw(performance.now(), Infinity);
  }

  function maxRadius() {
    return Math.hypot(w, h) * 0.72;
  }

  function drawPulse(cx: number, cy: number, dist: number) {
    const maxR = maxRadius();
    const r = ((dist % maxR) + maxR) % maxR;
    // sine envelope: born quiet, brightest mid-flight, gone at the edge
    const a = Math.sin((r / maxR) * Math.PI) * 0.16;
    if (a < 0.01 || r < 1) return;
    ctx.strokeStyle = PULSE;
    ctx.globalAlpha = a;
    ctx.lineWidth = 1.6;
    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, TAU);
    ctx.stroke();
    ctx.globalAlpha = 1;
  }

  function draw(t: number, dt: number) {
    ctx.fillStyle = FADE;
    ctx.fillRect(0, 0, w, h); // phosphor decay instead of a hard clear
    const maxR = maxRadius();
    ringSources.forEach((s, i) => {
      const cx = (s.ax + Math.sin(t * s.sx + s.p) * s.rx) * w;
      const cy = (s.ay + Math.cos(t * s.sy + s.p) * s.ry) * h;
      drawRings(cx, cy, t * 0.0045 + s.p * GAP);
      drawPulse(cx, cy, t * 0.021 + (i * maxR) / 3);
    });
    drawStamps(t);
    if (pointer.active) {
      // time-based lerp: identical feel at any frame rate
      const k = 1 - Math.exp(-(Number.isFinite(dt) ? dt : 16) / 180);
      pointer.x += (pointer.tx - pointer.x) * k;
      pointer.y += (pointer.ty - pointer.y) * k;
      stampAt(pointer.x, pointer.y, t); // the moving rings leave geometry behind
      drawRings(pointer.x, pointer.y, t * 0.008, LINE);
    }
  }

  function loop(t: number) {
    if (!running) return;
    const dt = lastT ? t - lastT : 16;
    lastT = t;
    draw(t, dt);
    rafId = requestAnimationFrame(loop);
  }

  function setRunning(on: boolean) {
    if (on === running) return;
    running = on;
    lastT = 0;
    if (on) rafId = requestAnimationFrame(loop);
    else cancelAnimationFrame(rafId);
  }

  resize();
  window.addEventListener('resize', resize);

  if (!reduced.matches) {
    const hero = canvas.closest('.hero')!;
    const vis = new IntersectionObserver(([entry]) => {
      setRunning(entry.isIntersecting && !document.hidden);
    });
    vis.observe(hero);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) setRunning(false);
      else setRunning(true);
    });
    window.addEventListener('pointermove', (e) => {
      if (e.pointerType !== 'mouse') return; // touch-scroll must not paint
      const rect = canvas.getBoundingClientRect();
      if (e.clientY < rect.bottom && e.clientY > rect.top) {
        if (!pointer.active) {
          pointer.x = e.clientX;
          pointer.y = e.clientY - rect.top;
          pointer.active = true;
        }
        pointer.tx = e.clientX;
        pointer.ty = e.clientY - rect.top;
      }
    }, { passive: true });
  } else {
    draw(4200, Infinity); // one static frame; the geometry stays, the motion goes
  }
</script>
