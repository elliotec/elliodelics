---
const email = 'mike@elliodelics.com';
---

<section class="hero" aria-label="Introduction">
  <canvas class="hero-field" aria-hidden="true"></canvas>

  <header class="hero-top container">
    <a class="wordmark brand" href="/">
      <svg class="shroom shroom-l" viewBox="0 0 20 40" aria-hidden="true">
        <path d="M2.5 10 A7.5 8 0 0 1 17.5 10 Z" />
        <path d="M11.5 10.5 C7 12.8 7.6 15.5 7.6 18.5 C7.6 21.8 4.4 22.7 3.2 23.5 C4.4 24.3 7.6 25.2 7.6 28.5 C7.6 31.5 7 34.6 11.5 36.6" />
      </svg>
      <span class="brand-name">elliodelics</span>
      <svg class="shroom shroom-r" viewBox="0 0 20 40" aria-hidden="true">
        <path d="M2.5 10 A7.5 8 0 0 1 17.5 10 Z" />
        <path d="M11.5 10.5 C7 12.8 7.6 15.5 7.6 18.5 C7.6 21.8 4.4 22.7 3.2 23.5 C4.4 24.3 7.6 25.2 7.6 28.5 C7.6 31.5 7 34.6 11.5 36.6" />
      </svg>
    </a>
    <a class="mono top-mail" href={`mailto:${email}`}>{email}</a>
  </header>

  <div class="hero-core container">
    <h1 class="display hero-title">
      <span class="line"><span class="line-inner">Software</span></span>
      <span class="line"><span class="line-inner">for the</span></span>
      <span class="line"><span class="line-inner">psychedelic</span></span>
      <span class="line"><span class="line-inner">industry<span class="dot">.</span></span></span>
    </h1>
    <p class="hero-sub">
      elliodelics is a software engineering studio for clinics, retreats,
      researchers, and the companies building around them. Somebody has
      to stay grounded.
    </p>
  </div>

  <div class="hero-cues">
    <a class="mono hero-cue" href="#manifesto">begin descent ↓</a>
    <a class="mono hero-cue" href="#contact">skip to contact ↘</a>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
    overflow: clip;
  }

  .hero-field {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: var(--z-canvas);
  }

  .hero-top {
    position: relative;
    z-index: var(--z-header);
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1.5rem;
    padding-block: 1.6rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.18em;
    font-size: 1.3rem;
    text-decoration: none;
    padding-block: 0.45em;
    margin-block: -0.45em;
  }

  .brand-name {
    font-family: 'MuseoModerno', var(--font-display);
    font-weight: 700;
    text-transform: lowercase; /* { elliodelics }, sibling to { elliotec } */
  }

  .shroom {
    height: 1.55em; /* braces overshoot the caps height, like real ones */
    width: auto;
    flex-shrink: 0;
  }
  .shroom path {
    fill: none;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .shroom-l path { stroke: var(--acid); }
  .shroom-r {
    scale: -1 1; /* mirror: the closing brace */
  }
  .shroom-r path { stroke: var(--bloom); }

  .top-mail {
    color: var(--ink-dim);
    text-decoration-color: var(--ink-faint);
    padding-block: 1em;
    margin-block: -1em;
  }
  .top-mail:hover { color: var(--acid); }

  @media (max-width: 40rem) {
    .top-mail { display: none; } /* the contact section carries the address */
  }

  .hero-core {
    position: relative;
    z-index: var(--z-content);
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-block: 3rem;
  }

  .hero-title {
    font-size: var(--text-hero);
    margin: 0;
  }

  .line {
    display: block;
    overflow: clip;
    padding-block: 0.04em; /* keep descenders unclipped */
  }

  .line-inner {
    display: inline-block;
  }

  .dot { color: var(--acid); }

  .hero-sub {
    max-width: var(--measure);
    margin-block: 2.2rem 0;
    font-size: var(--text-lg);
    line-height: 1.4;
    color: var(--ink-dim);
  }

  .hero-cues {
    position: relative;
    z-index: var(--z-content);
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem 2.2rem;
    margin: 0 var(--gutter) 1.6rem;
  }

  .hero-cue {
    color: var(--acid);
    text-decoration: none;
    /* thumb-sized target without shifting the layout */
    padding-block: 1em;
    margin-block: -1em;
  }
  .hero-cue:hover { text-decoration: underline; }

  /* -- entrance choreography (JS-gated; page is fine without) --
     The hidden states live in the keyframes (fill: backwards covers the
     delay), so the elements' static state is the finished layout: a
     renderer that never runs animations shows the hero, not a blank. */
  html.js .line-inner {
    animation: rise 1s var(--ease-expo) backwards;
  }
  html.js .line:nth-child(1) .line-inner { animation-delay: 0.05s; }
  html.js .line:nth-child(2) .line-inner { animation-delay: 0.13s; }
  html.js .line:nth-child(3) .line-inner { animation-delay: 0.21s; }
  html.js .line:nth-child(4) .line-inner { animation-delay: 0.29s; }

  html.js .hero-sub,
  html.js .hero-cues,
  html.js .hero-top {
    animation: appear 1.1s var(--ease-out) 0.6s backwards;
  }
  html.js .hero-top { animation-delay: 0.45s; }

  @keyframes rise {
    from { translate: 0 110%; }
    to { translate: 0 0; }
  }
  @keyframes appear {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    html.js .line-inner,
    html.js .hero-sub,
    html.js .hero-cues,
    html.js .hero-top { animation: none; }
  }
</style>

<script>
  // Interference field: concentric rings from drifting sources create a
  // slow moiré — closed-eye geometry, drawn like a schematic.
  // Rendering notes: no hard clears — each frame washes the canvas with a
  // translucent pass of the page green, so strokes decay like phosphor
  // persistence (hides temporal aliasing, leaves soft trails). The acid
  // highlight is a continuous expanding pulse, never an indexed ring that
  // would pop on phase wrap.
  const canvas = document.querySelector<HTMLCanvasElement>('.hero-field')!;
  const ctx = canvas.getContext('2d')!;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)');

  // Trails multiply brightness: steady-state stroke intensity ≈ line alpha
  // divided by fade alpha. Tune the pair together, not separately.
  // Ground color comes from the token, so a palette change can't desync it.
  const VOID =
    getComputedStyle(document.documentElement).getPropertyValue('--void').trim() ||
    'oklch(0.29 0.09 152)';
  const BG = VOID;
  const FADE = VOID.replace(')', ' / 0.35)');
  const LINE = 'oklch(0.7 0.13 305 / 0.07)'; // pointer rings
  const RING_LINE = 'oklch(0.7 0.13 305 / 0.055)'; // the interference field
  const STAMP = 'oklch(0.63 0.17 155 / 0.3)'; // laid-down geometry — deep emerald
  const STAMP_SOLID = 'oklch(0.63 0.17 155)'; // trail ripples; alpha per-ring
  const FLASH = 'oklch(0.975 0.008 152)'; // birth flash — white, reads on green
  const RIPPLE = 'oklch(0.7 0.13 305)'; // flower inner petals stay purple
  const PULSE = 'oklch(0.76 0.19 155)';
  const TAU = Math.PI * 2;
  const GAP = 34; // interference ring spacing
  const STAMP_R = 26; // Flower-of-Life circle radius = lattice spacing
  const BRUSH = STAMP_R * 1.2; // neighbourhood size: petals without a dense rope
  const STAMP_CAP = 300; // beyond this the oldest start dissolving immediately
  const STAMP_LIFE = 12000; // ms of growth before a circle starts to dissolve
  const STAMP_FADE = 2500; // ms to dissolve

  let w = 0, h = 0, dpr = 1;
  let running = false;
  let rafId = 0;
  let lastT = 0;
  let demoStart = -1;
  let demoBurst = false;

  const pointer = { x: -1, y: -1, tx: -1, ty: -1, active: false };

  // the interference field — three drifting ring emitters
  const ringSources = [
    { ax: 0.22, ay: 0.3, rx: 0.16, ry: 0.12, sx: 0.000041, sy: 0.000053, p: 0 },
    { ax: 0.78, ay: 0.42, rx: 0.14, ry: 0.16, sx: 0.000047, sy: 0.000037, p: 2.1 },
    { ax: 0.5, ay: 0.85, rx: 0.18, ry: 0.1, sx: 0.000035, sy: 0.000049, p: 4.2 },
  ];

  function drawRings(cx: number, cy: number, shift: number, color = RING_LINE) {
    const maxR = maxRadius() * 0.72;
    const offset = ((shift % GAP) + GAP) % GAP;
    ctx.strokeStyle = color;
    ctx.lineWidth = 1;
    for (let r = offset || 0.001; r < maxR; r += GAP) {
      ctx.beginPath();
      ctx.arc(cx, cy, r, 0, TAU);
      ctx.stroke();
    }
  }

  // -- Flower-of-Life stamping ------------------------------------------
  // The pointer lays circles onto a fixed triangular lattice with spacing =
  // radius, so every circle passes through its neighbours' centers — the
  // classic construction. Stamped circles bloom in and STAY.
  const stamps = new Map<string, { x: number; y: number; born: number; die: number }>();
  const ROW_H = STAMP_R * (Math.sqrt(3) / 2);

  function stampAt(px: number, py: number, t: number) {
    const row = Math.round(py / ROW_H);
    for (let dr = -2; dr <= 2; dr++) {
      const r = row + dr;
      const xOff = (r % 2 ? 0.5 : 0) * STAMP_R;
      const col = Math.round((px - xOff) / STAMP_R);
      for (let dc = -2; dc <= 2; dc++) {
        const c = col + dc;
        const x = c * STAMP_R + xOff;
        const y = r * ROW_H;
        if (Math.hypot(x - px, y - py) > BRUSH) continue;
        const key = r + ',' + c;
        if (stamps.has(key)) continue;
        stamps.set(key, { x, y, born: t, die: 0 });
        if (stamps.size > STAMP_CAP) {
          // over budget: start dissolving the oldest still-living circle now
          for (const s of stamps.values()) {
            if (!s.die) { s.die = t; break; }
          }
        }
      }
    }
  }

  // click/tap: a flower explodes at the point — two layers of petals bloom,
  // rotate slowly, and dissolve; a shockwave ring rides ahead of them
  const flowers: { x: number; y: number; start: number; seed: number }[] = [];
  const FLOWER_LIFE = 5200;
  const FLOWER_FADE = 1600;

  function burstAt(px: number, py: number, t: number) {
    flowers.push({ x: px, y: py, start: t, seed: Math.random() * TAU });
    if (flowers.length > 12) flowers.shift();
  }

  function drawPetal(
    cx: number,
    cy: number,
    angle: number,
    len: number,
    width: number
  ) {
    const tx = cx + Math.cos(angle) * len;
    const ty = cy + Math.sin(angle) * len;
    const mx = cx + Math.cos(angle) * len * 0.5;
    const my = cy + Math.sin(angle) * len * 0.5;
    const px = -Math.sin(angle) * width;
    const py = Math.cos(angle) * width;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.quadraticCurveTo(mx + px, my + py, tx, ty);
    ctx.quadraticCurveTo(mx - px, my - py, cx, cy);
    ctx.stroke();
  }

  function drawFlowers(t: number) {
    for (let i = flowers.length - 1; i >= 0; i--) {
      const f = flowers[i];
      const age = t - f.start;
      if (age > FLOWER_LIFE) { flowers.splice(i, 1); continue; }
      const fade = Math.min(1, (FLOWER_LIFE - age) / FLOWER_FADE);
      const rot = f.seed + age * 0.0001;

      // outer layer: 8 purple petals
      const k1 = Math.min(age / 900, 1);
      const bloom1 = 1 - Math.pow(1 - k1, 4);
      ctx.strokeStyle = RIPPLE;
      ctx.globalAlpha = 0.6 * fade;
      ctx.lineWidth = 1.4;
      for (let p = 0; p < 8; p++) {
        const a = rot + (p * TAU) / 8;
        drawPetal(f.x, f.y, a, 118 * bloom1, 26 * bloom1);
      }

      // inner layer: 6 lilac petals, offset and delayed
      const k2 = Math.min(Math.max(age - 260, 0) / 900, 1);
      const bloom2 = 1 - Math.pow(1 - k2, 4);
      if (bloom2 > 0) {
        ctx.strokeStyle = RIPPLE;
        ctx.globalAlpha = 0.5 * fade;
        ctx.lineWidth = 1.1;
        for (let p = 0; p < 6; p++) {
          const a = -rot * 1.6 + (p * TAU) / 6 + TAU / 16;
          drawPetal(f.x, f.y, a, 66 * bloom2, 19 * bloom2);
        }
      }

      // shockwave ring rides ahead
      const kr = age / 900;
      if (kr < 1) {
        ctx.strokeStyle = RIPPLE;
        ctx.globalAlpha = 0.5 * (1 - kr);
        ctx.lineWidth = 1.8;
        ctx.beginPath();
        ctx.arc(f.x, f.y, 20 + (1 - Math.pow(1 - kr, 3)) * 300, 0, TAU);
        ctx.stroke();
      }
    }
    ctx.globalAlpha = 1;
  }

  function drawStamps(t: number) {
    const RIPPLE_GAP = STAMP_R * 0.55;
    const RIPPLE_MAX = STAMP_R * 2.4; // ripples stay local to their circle
    ctx.lineWidth = 1;
    stamps.forEach((s, key) => {
      const age = t - s.born;
      if (age < 0) return; // staggered burst births: not born yet
      // lifecycle: grow for STAMP_LIFE, then dissolve and free the slot
      if (!s.die && age > STAMP_LIFE) s.die = t;
      let fade = 1;
      if (s.die) {
        fade = 1 - (t - s.die) / STAMP_FADE;
        if (fade <= 0) {
          stamps.delete(key);
          return;
        }
      }
      const k = Math.min(age / 700, 1);
      const ease = 1 - Math.pow(1 - k, 4); // bloom: ease-out-quart
      // every circle keeps growing after its bloom: 7px/s toward a 2.6× cap,
      // so painted regions thicken into mandala overlap
      const base =
        STAMP_R * ease + Math.min(Math.max(age - 700, 0) * 0.007, STAMP_R * 1.6);
      ctx.strokeStyle = STAMP;
      ctx.globalAlpha = (0.35 + 0.65 * ease) * fade;
      ctx.beginPath();
      ctx.arc(s.x, s.y, base, 0, TAU);
      ctx.stroke();
      if (age < 300) {
        // flash at birth — white, so it reads on the green trail
        ctx.strokeStyle = FLASH;
        ctx.globalAlpha = 0.4 * (1 - age / 300);
        ctx.beginPath();
        ctx.arc(s.x, s.y, base, 0, TAU);
        ctx.stroke();
        return;
      }
      // ripples ride the growing edge, fading as they travel
      const span = RIPPLE_MAX - STAMP_R;
      const shift = (age * 0.014) % RIPPLE_GAP;
      ctx.strokeStyle = STAMP_SOLID;
      for (let r = base + shift; r < base + span; r += RIPPLE_GAP) {
        ctx.globalAlpha = 0.2 * (1 - (r - base) / span) * fade;
        ctx.beginPath();
        ctx.arc(s.x, s.y, r, 0, TAU);
        ctx.stroke();
      }
    });
    ctx.globalAlpha = 1;
  }

  function resize() {
    dpr = Math.min(window.devicePixelRatio || 1, 1.75);
    w = canvas.clientWidth;
    h = canvas.clientHeight;
    canvas.width = Math.round(w * dpr);
    canvas.height = Math.round(h * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.fillStyle = BG;
    ctx.fillRect(0, 0, w, h);
    if (!running) draw(performance.now(), Infinity);
  }

  function maxRadius() {
    return Math.hypot(w, h) * 0.72;
  }

  function drawPulse(cx: number, cy: number, dist: number) {
    const maxR = maxRadius();
    const r = ((dist % maxR) + maxR) % maxR;
    // sine envelope: born quiet, brightest mid-flight, gone at the edge
    const a = Math.sin((r / maxR) * Math.PI) * 0.16;
    if (a < 0.01 || r < 1) return;
    ctx.strokeStyle = PULSE;
    ctx.globalAlpha = a;
    ctx.lineWidth = 1.6;
    ctx.beginPath();
    ctx.arc(cx, cy, r, 0, TAU);
    ctx.stroke();
    ctx.globalAlpha = 1;
  }

  function draw(t: number, dt: number) {
    ctx.fillStyle = FADE;
    ctx.fillRect(0, 0, w, h); // phosphor decay instead of a hard clear
    const maxR = maxRadius();
    ringSources.forEach((s, i) => {
      const cx = (s.ax + Math.sin(t * s.sx + s.p) * s.rx) * w;
      const cy = (s.ay + Math.cos(t * s.sy + s.p) * s.ry) * h;
      drawRings(cx, cy, t * 0.0045 + s.p * GAP);
      drawPulse(cx, cy, t * 0.021 + (i * maxR) / 3);
    });
    // intro stroke: the field paints once by itself, then hands over the
    // brush — otherwise the interaction stays a secret
    if (demoStart < 0) demoStart = t + 1400;
    const dk = (t - demoStart) / 2600;
    // on narrow viewports the sweep stays low, out from under the hero copy
    const narrow = w < 640;
    if (dk >= 0 && dk <= 1) {
      const dx = w * (narrow ? 0.25 + 0.62 * dk : 0.32 + 0.46 * dk);
      const dy = narrow
        ? h * (0.85 - 0.13 * dk + Math.sin(dk * Math.PI * 2) * 0.04)
        : h * (0.74 - 0.36 * dk + Math.sin(dk * Math.PI * 2) * 0.07);
      stampAt(dx, dy, t);
    } else if (dk > 1 && !demoBurst) {
      // the stroke ends the way a click begins: a flower
      demoBurst = true;
      if (narrow) burstAt(w * 0.87, h * 0.72, t);
      else burstAt(w * 0.78, h * 0.38, t);
    }
    drawStamps(t);
    drawFlowers(t);
    if (pointer.active) {
      // time-based lerp: identical feel at any frame rate
      const k = 1 - Math.exp(-(Number.isFinite(dt) ? dt : 16) / 180);
      pointer.x += (pointer.tx - pointer.x) * k;
      pointer.y += (pointer.ty - pointer.y) * k;
      stampAt(pointer.x, pointer.y, t); // the moving rings leave geometry behind
      drawRings(pointer.x, pointer.y, t * 0.008, LINE);
    }
  }

  function loop(t: number) {
    if (!running) return;
    const dt = lastT ? t - lastT : 16;
    lastT = t;
    draw(t, dt);
    rafId = requestAnimationFrame(loop);
  }

  function setRunning(on: boolean) {
    if (on === running) return;
    running = on;
    lastT = 0;
    if (on) rafId = requestAnimationFrame(loop);
    else cancelAnimationFrame(rafId);
  }

  resize();
  window.addEventListener('resize', resize);

  // the wordmark scrolls home instead of reloading the whole page and
  // replaying the entrance
  document.querySelector('.brand')?.addEventListener('click', (e) => {
    const m = e as MouseEvent;
    // modified clicks keep their browser meaning (open home in a new tab)
    if (m.metaKey || m.ctrlKey || m.shiftKey || m.altKey || m.button !== 0) return;
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: reduced.matches ? 'auto' : 'smooth' });
  });

  if (!reduced.matches) {
    const hero = canvas.closest('.hero')!;
    const vis = new IntersectionObserver(([entry]) => {
      setRunning(entry.isIntersecting && !document.hidden);
    });
    vis.observe(hero);
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) setRunning(false);
      else setRunning(true);
    });
    // click/tap anywhere open in the hero: rosette burst (all pointer types —
    // a tap is deliberate in a way scrolling isn't)
    hero.addEventListener('click', (e) => {
      if ((e.target as Element).closest('a, button')) return;
      const rect = canvas.getBoundingClientRect();
      burstAt(e.clientX, e.clientY - rect.top, performance.now());
    });
    window.addEventListener('pointermove', (e) => {
      if (e.pointerType !== 'mouse') return; // touch-scroll must not paint
      const rect = canvas.getBoundingClientRect();
      if (e.clientY < rect.bottom && e.clientY > rect.top) {
        if (!pointer.active) {
          pointer.x = e.clientX;
          pointer.y = e.clientY - rect.top;
          pointer.active = true;
        }
        pointer.tx = e.clientX;
        pointer.ty = e.clientY - rect.top;
      } else {
        // below the band: the halo leaves with the mouse instead of
        // haunting its last position
        pointer.active = false;
      }
    }, { passive: true });
    // same when the mouse leaves the document entirely
    document.addEventListener('pointerleave', () => { pointer.active = false; });
    window.addEventListener('blur', () => { pointer.active = false; });
  } else {
    draw(4200, Infinity); // one static frame; the geometry stays, the motion goes
  }
</script>
