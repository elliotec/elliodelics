---
const email = 'mike@elliodelics.com';
// five offerings, framed around the buyer's situation and outcome — the
// engineering categories live inside the descriptions, not the titles.
// Five breaks the four-chunk rhythm deliberately: fractional serves a
// different buyer and earns its own row.
const services = [
  {
    title: 'Survive the questionnaire',
    desc: 'An investor’s security review, a partner’s RFP, an insurer’s checklist. We map the data you hold, close the gaps, and write the answers down early.',
    glyph: 'M11 4 H29 V28 H11 Z M15 10 H25 M15 15 H25 M15 20 H20',
  },
  {
    title: 'Protect the data',
    desc: 'Data protection as architecture, not paperwork. Minimization, encryption, retention, and GDPR built in from the start.',
    glyph: 'M13 15 V10 A7 7 0 0 1 27 10 V15 M9 15 H31 V27 H9 Z M20 19 V23',
  },
  {
    title: 'Govern the AI',
    desc: 'The notetakers and chatbots already touching sensitive data. We inventory them, read the terms nobody read, and fence what they reach.',
    glyph: 'M14 11 H26 V23 H14 Z M18 11 V7 M22 11 V7 M18 23 V27 M22 23 V27 M14 14 H10 M14 20 H10 M26 14 H30 M26 20 H30 M18 15 H22 V19 H18 Z',
  },
  {
    title: 'Ship the product',
    desc: 'From prototype to production. Platforms, APIs, and the unglamorous plumbing that keeps them standing.',
    glyph: 'M4 16 L12 16 M16 16 L24 16 M28 16 L36 16 M14 16 A2 2 0 1 0 14 15.99 M26 16 A2 2 0 1 0 26 15.99 M36 10 L36 22',
  },
  {
    title: 'Fractional engineering leadership',
    desc: 'A director of engineering without the full-time hire. Hiring, architecture, and roadmaps that tell you the truth.',
    glyph: 'M20 7 A2.5 2.5 0 1 0 20 6.99 M10 25 A2.5 2.5 0 1 0 10 24.99 M30 25 A2.5 2.5 0 1 0 30 24.99 M20 10 L20 14 M20 14 L11 22 M20 14 L29 22',
  },
];
---

<section class="services" id="services" aria-labelledby="services-title" tabindex="-1">
  <div class="container">
    <h2 class="display sec-title" id="services-title">What we handle<span class="dot">.</span></h2>
    <ul class="index">
      {services.map((s, i) => (
        <li class="row draw" style={`--draw-delay: ${i * 0.08}s`}>
          <svg class="glyph" viewBox="0 0 40 32" aria-hidden="true">
            {/* one path per subpath, each with its own normalized length:
                they draw simultaneously, so the icon sketches in as one
                gesture instead of a sequential dash sprint */}
            {s.glyph.split(/(?=M)/).filter(Boolean).map((seg) => (
              <path d={seg} pathLength="1" />
            ))}
          </svg>
          <h3 class="row-title">{s.title}</h3>
          <p class="row-desc">{s.desc}</p>
          <a
            class="row-cue mono"
            href="#contact"
            data-subject={`${s.title} · inquiry`}
            aria-label={`take this to contact · ${s.title.toLowerCase()}`}
          >take this to contact ↘</a>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .services {
    background: var(--void);
    padding-block: var(--space-section);
  }

  /* scroll target only — the ring belongs on controls, not sections */
  .services:focus-visible { outline: none; }

  .sec-title {
    font-size: var(--text-h2);
    margin: 0 0 clamp(3rem, 7vh, 5rem);
  }

  .dot { color: var(--acid); }

  .index {
    list-style: none;
    margin: 0;
    padding: 0;
    border-block-start: 1px solid var(--ink-faint);
  }

  .row {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    grid-template-areas: 'glyph' 'title' 'desc' 'cue';
    column-gap: clamp(1rem, 3vw, 2.5rem);
    align-items: start;
    padding: clamp(1.6rem, 4vh, 2.6rem) clamp(0.5rem, 1.5vw, 1.25rem);
    border-block-end: 1px solid var(--ink-faint);
    transition: background 0.35s var(--ease-out), color 0.35s var(--ease-out);
  }

  @media (min-width: 40rem) {
    .row {
      grid-template-columns: 3.5rem minmax(0, 1fr);
      grid-template-areas: 'glyph title' 'glyph desc' 'glyph cue';
    }
  }

  @media (min-width: 52rem) {
    .row {
      grid-template-columns: 3.5rem minmax(0, 1.1fr) minmax(0, 1fr);
      grid-template-areas: 'glyph title desc' 'glyph title cue';
    }
  }

  .row-cue {
    grid-area: cue;
    justify-self: start;
    margin-block-start: 0.4rem;
    /* generous hit area without moving the layout */
    padding: 1.2em 0.9em 1.2em 0;
    margin-block: -0.5em;
    color: var(--acid);
    text-decoration: none;
    transition: color 0.35s var(--ease-out);
  }
  .row-cue:hover { text-decoration: underline; }
  @media (hover: hover) {
    .row:has(.row-cue:hover) .row-cue { color: var(--void-abyss); }
  }
  .row:has(.row-cue:focus-visible) .row-cue { color: var(--void-abyss); }

  /* the acid flood follows the actual link — the cue — not the whole row,
     so hovering content never advertises a click that isn't there */
  @media (hover: hover) {
    .row:has(.row-cue:hover) {
      background: var(--acid);
      color: var(--void-abyss);
    }
  }
  .row:has(.row-cue:focus-visible) {
    background: var(--acid);
    color: var(--void-abyss);
  }

  .glyph {
    grid-area: glyph;
    width: 2.6rem;
    height: auto;
    margin-block: 0.4rem 0.7rem;
  }
  @media (min-width: 40rem) {
    .glyph { margin-block-end: 0; }
  }
  .glyph path {
    fill: none;
    stroke: var(--acid);
    stroke-width: 1.6;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: stroke 0.35s var(--ease-out);
    /* normalized by pathLength=1: a full-length dash reads as a solid
       stroke at rest, and the keyframe draws it in from offset 1 */
    stroke-dasharray: 1;
  }
  .row.draw.in .glyph path {
    animation: stroke-draw 2.4s var(--ease-out) calc(var(--draw-delay, 0s) + 0.15s) backwards;
  }
  @media (prefers-reduced-motion: reduce) {
    .row.draw.in .glyph path { animation: none; }
  }
  @media (hover: hover) {
    .row:has(.row-cue:hover) .glyph path { stroke: var(--void-abyss); }
  }
  .row:has(.row-cue:focus-visible) .glyph path { stroke: var(--void-abyss); }

  .row-title {
    grid-area: title;
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.02;
    font-size: var(--text-h3);
    margin: 0;
  }
  @media (max-width: 25rem) {
    /* QUESTIONNAIRE is unbreakable; give it room on the smallest phones */
    .row-title { font-size: 7vw; }
  }

  .row-desc {
    grid-area: desc;
    max-width: 44ch;
    margin: 0.7rem 0 0;
    color: var(--ink-dim);
    transition: color 0.35s var(--ease-out);
  }
  @media (min-width: 52rem) {
    .row-desc { margin-block-start: 0.35rem; }
  }
  @media (hover: hover) {
    .row:has(.row-cue:hover) .row-desc { color: var(--void-deep); }
  }
  .row:has(.row-cue:focus-visible) .row-desc { color: var(--void-deep); }

  /* the acid focus ring would vanish into the acid flood */
  .row-cue:focus-visible { outline-color: var(--void-abyss); }
</style>

<script>
  // cues route to the contact section (which carries the copy fallback for
  // machines with no mail handler), hand their subject to the mail link,
  // and say so out loud — the subject echo keeps the handoff honest
  const mail = document.querySelector<HTMLAnchorElement>('.contact .mail');
  const echo = document.querySelector<HTMLElement>('.contact [data-subject-echo]');
  const echoText = echo?.querySelector<HTMLElement>('[data-echo-text]');
  document.querySelectorAll<HTMLAnchorElement>('.row-cue').forEach((cue) => {
    cue.addEventListener('click', (e) => {
      // modified clicks keep their browser meaning and must not mutate
      // this page's mail link as a side effect
      const m = e as MouseEvent;
      if (m.metaKey || m.ctrlKey || m.shiftKey || m.altKey || m.button !== 0) return;
      if (!mail || !cue.dataset.subject) return;
      const base = mail.getAttribute('href')!.split('?')[0];
      mail.setAttribute('href', `${base}?subject=${encodeURIComponent(cue.dataset.subject)}`);
      if (echo && echoText) {
        echoText.textContent = `subject · ${cue.dataset.subject.split(' · ')[0].toLowerCase()} `;
        echo.hidden = false;
        // the handoff is announced, not just shown — same live region the
        // copy button uses
        const status = document.querySelector<HTMLElement>('.contact [role="status"]');
        if (status) status.textContent = `Email subject set to ${cue.dataset.subject}.`;
      }
      // a cue to contact is a jump, not a journey — same instant-scroll
      // rule the hero's skip cue follows
      e.preventDefault();
      const target = document.querySelector<HTMLElement>('#contact');
      target?.scrollIntoView({ behavior: 'instant', block: 'start' });
      target?.focus({ preventScroll: true });
      history.pushState(null, '', '#contact');
    });
  });
</script>
