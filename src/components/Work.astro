---
const cases = [
  {
    org: 'Mindscape Collective',
    url: 'https://mindscapecollective.org',
    role: 'founder & executive director',
    body: 'An open library of the world’s psychedelic and consciousness research, aggregating a massive collection of peer-reviewed articles from a dozen sources and summarizing them in plain language, free to everyone. No paywall, no gatekeeping.',
  },
  {
    org: 'Psymposia',
    url: 'https://psymposia.com',
    role: 'infrastructure',
    body: 'Moving the psychedelic media nonprofit’s tech stack to open-source, encrypted infrastructure. Privacy engineering for independent journalism in a sensitive field.',
  },
  {
    org: 'Psychedelia-Stiftung',
    url: 'https://psychedelia-stiftung.de',
    role: 'engineering partner',
    bodyPre: 'Websites, systems, and GDPR-compliant intake forms for the German foundation’s work on ethical, evidence-backed psychedelic retreats, including ',
    linkText: 'Psychedelia Retreats',
    linkHref: 'https://psychedelia-retreats.com',
    bodyPost: '.',
  },
  {
    org: 'Dutchie',
    url: 'https://business.dutchie.com',
    role: 'director of engineering',
    body: 'Grew the engineering department to 60 engineers across 10 teams through funding rounds and acquisitions, in cannabis dispensary software where security, data privacy, and compliance are the product.',
  },
];
---

<section class="work" aria-labelledby="work-title">
  <span class="sr-only" id="new-tab-note">opens in new tab</span>
  <div class="container">
  <h2 class="display sec-title reveal" id="work-title">Field reports</h2>
  <p class="note mono reveal">no anonymized case studies · all of this is public record</p>

  <ul class="reports">
    {cases.map((c, i) => (
      <li class="report reveal" style={`--reveal-delay: ${i * 0.08}s`}>
        <span class="mark" aria-hidden="true">✺</span>
        <div class="org-line">
          <h3 class="org">
            {c.url ? (
              <a href={c.url} target="_blank" rel="noopener" aria-describedby="new-tab-note">
                {c.org}<span class="ext" aria-hidden="true">↗</span>
              </a>
            ) : (
              c.org
            )}
          </h3>
          <span class="ledger" aria-hidden="true"></span>
          <p class="role mono">{c.role}</p>
        </div>
        <p class="body">
          {c.bodyPre ?? c.body}{c.linkHref && (
            <a
              class="body-link"
              href={c.linkHref}
              target="_blank"
              rel="noopener"
              aria-describedby="new-tab-note"
            >{c.linkText}<span class="ext" aria-hidden="true">↗</span></a>
          )}{c.bodyPost}
        </p>
      </li>
    ))}
  </ul>
  </div>
</section>

<style>
  .work {
    background: var(--void-deep);
    padding-block: var(--space-section);
  }

  .sec-title {
    font-size: var(--text-h2);
    margin: 0;
    text-align: right;
  }

  .note {
    text-align: right;
    color: var(--ink-dim);
    margin: 0.8rem 0 clamp(3rem, 7vh, 5rem);
  }

  .reports {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: clamp(2.5rem, 6vh, 4rem);
  }

  .report {
    display: grid;
    grid-template-columns: 2rem minmax(0, 1fr);
    column-gap: 1.2rem;
    max-width: 46rem;
  }

  /* alternate: pull even reports right for rhythm */
  .report:nth-child(even) { margin-inline-start: auto; }

  .body-link {
    color: inherit;
    text-decoration: underline;
    text-decoration-color: var(--ink-faint);
    text-underline-offset: 0.18em;
    transition: color 0.25s var(--ease-out);
    padding-block: 0.35em; /* inline: extends hit box, not line height */
  }
  .body-link:hover,
  .body-link:focus-visible { color: var(--acid); }

  .mark {
    grid-row: span 4; /* org-line + body; extra rows collapse */
    color: var(--acid);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  /* elliot.ec-style ledger line: org ······ role */
  .org-line {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4rem 1em;
  }

  .ledger {
    flex: 1;
    min-width: 3rem;
    border-block-end: 1px dotted var(--ink-faint);
    align-self: center;
  }
  @media (max-width: 40rem) {
    .ledger { display: none; }
  }

  .org {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.05;
    font-size: clamp(1.5rem, 1.1rem + 1.8vw, 2.4rem);
    margin: 0;
  }

  .org a {
    color: inherit;
    text-decoration: none;
    transition: color 0.25s var(--ease-out);
    /* thumb-sized hit area; padding on inline links extends the hit box
       without pushing lines apart */
    padding-block: 0.35em;
  }
  .org a:hover,
  .org a:focus-visible { color: var(--acid); }

  .ext {
    font-family: var(--font-mono);
    font-size: 0.45em;
    font-weight: 400;
    vertical-align: 0.9em;
    margin-inline-start: 0.4em;
    color: var(--acid);
  }

  .role {
    margin: 0;
    color: var(--ink-dim);
  }

  .body {
    margin: 0.9rem 0 0;
    font-size: var(--text-body);
    line-height: 1.55;
    color: var(--ink-dim);
    max-width: 52ch;
  }
</style>
