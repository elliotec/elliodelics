---
// ordered by relevance to a buying clinic: vertical client work first,
// scale proof second, the nonprofits after. `rel` is the honest
// relationship tag — the "public record" claim invites the audit, so the
// answer is printed before anyone has to dig for it.
const cases = [
  {
    org: 'Psychedelia-Stiftung',
    logo: '/logos/stiftung.webp',
    url: 'https://psychedelia-stiftung.de',
    rel: 'client',
    role: 'engineering partner',
    body: 'Websites, systems, and GDPR-compliant intake forms for the German foundation’s ethical psychedelic retreats.',
  },
  {
    org: 'Dutchie',
    logo: '/logos/dutchie.webp',
    url: 'https://business.dutchie.com',
    rel: 'engineering leadership',
    role: '60 engineers, 10 teams',
    body: 'Cannabis dispensary software, where security, data privacy, and compliance are the product.',
  },
  {
    org: 'Psymposia',
    logo: '/logos/psymposia.svg',
    url: 'https://psymposia.com',
    rel: 'pro bono',
    role: 'infrastructure & migrations',
    body: 'Open-source, encrypted infrastructure for the psychedelic media nonprofit.',
  },
  // {
  //   org: 'Josie Kins',
  //   logo: '/logos/josie.webp',
  //   logoH: '1.7rem', /* slim wordmark */
  //   url: 'https://josiekins.xyz',
  //   rel: 'collaborator',
  //   role: 'collaborator',
  //   body: 'Collaborating on setting up her community Matrix server and on data projects.',
  // },
  {
    org: 'The Consciousness Library',
    logo: '/logos/mindscape.webp',
    logoH: '4.6rem', /* tall narrow mark reads small at the shared height */
    url: 'https://consciousnesslibrary.org',
    rel: 'founder',
    role: 'executive director',
    body: 'An open library of tens of thousands of research articles, summarized in plain language, free to everyone.',
  },
];
---

<section class="work" id="field-reports" aria-labelledby="work-title" tabindex="-1">
  <span class="sr-only" id="new-tab-note">opens in new tab</span>
  <div class="container">
  <h2 class="display sec-title" id="work-title">Field reports<span class="dot">.</span></h2>
  <p class="note mono">no anonymized case studies · all of this is public record</p>

  <ul class="reports">
    {cases.map((c, i) => (
      <li class="report draw" style={`--draw-delay: ${i * 0.08}s`}>
        <img
          class="orglogo"
          src={c.logo}
          alt=""
          height="54"
          loading="lazy"
          decoding="async"
          style={c.logoH ? `height: ${c.logoH}` : undefined}
        />
        <div class="org-line">
          <h3 class="org">
            {c.url ? (
              <a href={c.url} target="_blank" rel="noopener" aria-describedby="new-tab-note">
                {c.org}<span class="ext" aria-hidden="true">↗</span>
              </a>
            ) : (
              c.org
            )}
          </h3>
          <span class="ledger" aria-hidden="true"></span>
        </div>
        <p class="role mono">{c.rel} · {c.role}</p>
        <p class="body">{c.body}</p>
      </li>
    ))}
  </ul>
  </div>
</section>

<style>
  .work {
    background: var(--void-deep);
    padding-block: var(--space-section);
  }

  /* scroll target only — the ring belongs on controls, not sections */
  .work:focus-visible { outline: none; }

  .sec-title {
    font-size: var(--text-h2);
    margin: 0;
    text-align: right;
  }

  .dot { color: var(--acid); }

  .note {
    text-align: right;
    color: var(--ink-dim);
    margin: 0.8rem 0 clamp(3rem, 7vh, 5rem);
  }

  .reports {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: clamp(1.4rem, 3vh, 2rem);
  }

  .report {
    max-width: 46rem;
  }

  /* alternate: pull even reports right for rhythm */
  .report:nth-child(even) { margin-inline-start: auto; }

  /* each org's real mark, unified as white line-art on the void */
  .orglogo {
    display: block;
    height: 3.4rem;
    width: auto;
    margin-block-end: 1.1rem;
    filter: brightness(0) invert(1);
    opacity: 0.92;
  }

  @media (forced-colors: active) {
    /* white-forced logos vanish on forced-white backgrounds; the originals
       carry their own contrast */
    .orglogo { filter: none; opacity: 1; }
  }

  /* elliot.ec-style ledger line: org ······ role */
  .org-line {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4rem 1em;
  }

  .ledger {
    flex: 1;
    min-width: 3rem;
    /* 2px, not the 1px hairline norm: a moving line needs enough ink
       to be watched, not just noticed */
    border-block-end: 2px dotted var(--ink-faint);
    align-self: center;
    /* explicit resting inset: clip-path can't interpolate from inset()
       to none, so without this the sweep degrades to a discrete blink */
    clip-path: inset(0 0 0 0);
  }
  .report.draw.in .ledger {
    animation: sweep-in 4.5s var(--ease-out) calc(var(--draw-delay, 0s) + 0.2s) backwards;
  }
  @media (prefers-reduced-motion: reduce) {
    .report.draw.in .ledger { animation: none; }
  }
  @media (max-width: 40rem) {
    .ledger { display: none; }
  }

  .org {
    font-family: var(--font-display);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1.05;
    font-size: clamp(1.5rem, 1.1rem + 1.8vw, 2.4rem);
    margin: 0;
  }

  .org a {
    color: inherit;
    text-decoration: none;
    transition: color 0.25s var(--ease-out);
    /* ≥44px hit area on all pointers (AAA 2.5.5); padding on inline links
       extends the hit box without pushing lines apart */
    padding-block: 0.45em;
  }
  .org a:hover,
  .org a:focus-visible { color: var(--acid); }

  .ext {
    font-family: var(--font-mono);
    font-size: 0.45em;
    font-weight: 400;
    vertical-align: 0.9em;
    margin-inline-start: 0.4em;
    color: var(--acid);
  }

  .role {
    margin: 0.45rem 0 0;
    color: var(--ink-dim);
  }

  .body {
    margin: 0.5rem 0 0;
    font-size: var(--text-body);
    line-height: 1.55;
    color: var(--ink-dim);
    max-width: 52ch;
  }
</style>
