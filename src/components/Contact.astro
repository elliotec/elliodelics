---
const email = 'mike@elliodelics.com';
---

<section class="contact" id="contact" aria-labelledby="contact-title" tabindex="-1">
  <div class="container">
    <h2 class="display big draw" id="contact-title">
      Tell us what you’re building<span class="dot">.</span>
    </h2>
    {/* filled by the service cues — the subject handoff, said out loud,
        right above the mail link where the post-scroll eye lands.
        Dismissing it resets the link to a plain address. */}
    <p class="mono echo" data-subject-echo hidden>
      <span data-echo-text></span>
      <button class="echo-clear" type="button" aria-label="clear the subject">×</button>
    </p>
    <div class="actions">
      <a class="mail" href={`mailto:${email}`} data-magnet>
        {email}
        <span class="sweep" aria-hidden="true"></span>
      </a>
      <button class="mono copy" type="button" data-copy={email}>
        <span class="copy-label">copy address</span>
        <span class="copy-done" aria-hidden="true">copied ✺</span>
        <span class="copy-fail" aria-hidden="true">copy failed</span>
      </button>
      <span class="sr-only" role="status"></span>
    </div>
    <div class="mono next">
      <p>goes straight to Mike · no funnel, no sales team</p>
      <p>the first call is free · replies usually within a few days</p>
    </div>
  </div>
</section>

<style>
  .contact:focus-visible { outline: none; } /* scroll target, not a control */

  .next {
    margin: 2rem 0 0;
    color: var(--ink-dim);
    max-width: 62ch;
  }
  .next p { margin: 0; }
  .next p + p { margin-block-start: 0.6em; }

  /* acid annotation above the mail link: it describes what the link will do.
     Appears mid-scroll (off-screen), so its layout shift is never seen. */
  .echo {
    margin: clamp(2rem, 6vh, 3.5rem) 0 -1.4rem;
    color: var(--acid);
  }

  .echo-clear {
    background: none;
    border: none;
    color: var(--ink-dim);
    font: inherit;
    cursor: pointer;
    /* ≥44px target without growing the line */
    padding: 1em;
    margin: -1em -1em -1em -0.4em;
  }
  .echo-clear:hover { color: var(--acid); }

  .contact {
    background: var(--void-abyss);
    padding-block-start: var(--space-section);
    display: flex;
    flex-direction: column;
    /* the footer landmark now sits outside the section; its height is
       carved out here so contact + footer still read as one viewport */
    min-height: calc(88svh - 8rem);
  }

  .big {
    font-size: var(--text-hero);
    max-width: 12ch;
    margin: 0;
  }

  .dot {
    color: var(--acid);
    display: inline-block; /* scale needs a box */
  }
  .big.draw.in .dot {
    animation: dot-pop 1.2s var(--ease-expo) 0.55s backwards;
  }
  @media (prefers-reduced-motion: reduce) {
    .big.draw.in .dot { animation: none; }
  }

  .actions {
    margin-block-start: clamp(3rem, 8vh, 5.5rem);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem 2.5rem;
  }

  .mail {
    position: relative;
    display: inline-block;
    font-family: var(--font-mono);
    font-size: clamp(1.1rem, 0.6rem + 2.4vw, 2.1rem);
    letter-spacing: 0.01em;
    color: var(--acid);
    text-decoration: none;
    padding-block: 0.3em;
    overflow-wrap: anywhere;
  }

  /* AAA target size (2.5.5): ≥44px on fine pointers too — an invisible
     extender grows the hit box without touching the layout */
  .mail::before {
    content: '';
    position: absolute;
    inset-block: -4px;
    inset-inline: 0;
  }

  .sweep {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 2px;
    background: var(--acid);
    transform-origin: left;
    scale: 0 1;
    transition: scale 0.5s var(--ease-expo);
  }
  .mail:hover .sweep,
  .mail:focus-visible .sweep { scale: 1 1; }

  .copy {
    position: relative;
    background: none;
    /* control boundary, not a hairline: 3.6:1 on abyss (WCAG 1.4.11),
       where ink-faint's 2.2:1 is reserved for decorative rules */
    border: 1px solid oklch(0.975 0.008 152 / 0.42);
    color: var(--ink-dim);
    padding: 0.7em 1.3em;
    border-radius: 99px;
    cursor: pointer;
    transition: border-color 0.3s var(--ease-out), color 0.3s var(--ease-out);
  }
  /* AAA target size on fine pointers: the pill stays its size, the
     clickable area doesn't */
  .copy::before {
    content: '';
    position: absolute;
    inset: -5px;
    border-radius: 99px;
  }

  @media (pointer: coarse) {
    .copy { padding: 1em 1.5em; } /* ≥44px tall on touch */
    .mail { padding-block: 0.75em; }
  }
  .copy:hover {
    border-color: var(--acid);
    color: var(--acid);
  }

  .copy-done,
  .copy-fail {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    border-radius: 99px;
    opacity: 0;
    transition: opacity 0.25s var(--ease-out);
    white-space: nowrap;
  }
  .copy-done {
    background: var(--acid);
    color: var(--void-abyss);
  }
  .copy-fail {
    background: var(--void-lift);
    color: var(--ink);
    border: 1px solid var(--ink-faint);
  }
  .copy.did .copy-done { opacity: 1; }
  .copy.failed .copy-fail { opacity: 1; }
  /* the failure state keeps its own palette even while hovered */
  .copy.failed,
  .copy.failed:hover {
    color: var(--ink);
    border-color: var(--ink-faint);
  }

</style>

<script>
  // copy-to-clipboard with visible + announced confirmation, and an honest
  // failure state (clipboard can be blocked or unavailable). One tracked
  // timer, so a double-click can't stack timeouts and flicker the state.
  const btn = document.querySelector<HTMLButtonElement>('[data-copy]');
  const status = document.querySelector<HTMLElement>('.actions [role="status"]');
  let copyTimer: ReturnType<typeof setTimeout>;
  btn?.addEventListener('click', async () => {
    clearTimeout(copyTimer);
    try {
      await navigator.clipboard.writeText(btn.dataset.copy!);
      btn.classList.remove('failed');
      btn.classList.add('did');
      if (status) status.textContent = 'Email address copied.';
      copyTimer = setTimeout(() => btn.classList.remove('did'), 1600);
    } catch {
      btn.classList.remove('did');
      btn.classList.add('failed');
      if (status) status.textContent = 'Copy failed. Use the email link instead.';
      copyTimer = setTimeout(() => btn.classList.remove('failed'), 2400);
    }
  });

  // dismissing the subject echo resets the mail link to a plain address
  const echoWrap = document.querySelector<HTMLElement>('[data-subject-echo]');
  echoWrap?.querySelector('.echo-clear')?.addEventListener('click', () => {
    echoWrap.hidden = true;
    const m = document.querySelector<HTMLAnchorElement>('.contact .mail');
    m?.setAttribute('href', m.getAttribute('href')!.split('?')[0]);
  });

  // magnetic pull on the email link — skipped for reduced motion
  const mail = document.querySelector<HTMLAnchorElement>('[data-magnet]');
  if (mail && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const strength = 0.1; /* alive, not lunging */
    mail.style.transition = 'translate 0.3s cubic-bezier(0.22, 1, 0.36, 1)';
    mail.addEventListener('pointermove', (e) => {
      const r = mail.getBoundingClientRect();
      const dx = e.clientX - (r.left + r.width / 2);
      const dy = e.clientY - (r.top + r.height / 2);
      mail.style.translate = `${dx * strength}px ${dy * strength}px`;
    });
    mail.addEventListener('pointerleave', () => {
      mail.style.translate = '0 0';
    });
  }
</script>
