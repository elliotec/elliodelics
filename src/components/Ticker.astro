---
// Dual-fluency vocabulary: one engineering term, one field term, per pair.
const pairs = [
  ['code review', 'peer review'],
  ['data privacy', 'harm reduction'],
  ['audit trails', 'altered states'],
  ['observability', 'introspection'],
  ['GDPR', 'informed consent'],
  ['feature flags', 'titration'],
  ['role-based access', 'set & setting'],
  ['documentation', 'trip reports'],
  ['3rd-party integrations', 'integration circles'],
  ['SOC 2', 'trip sitting'],
  ['incident response', 'challenging experiences'],
  ['compliance', 'ceremony'],
  ['zero-downtime deploys', 'non-ordinary states'],
  ['data pipelines', 'dosing protocols'],
];
---

{/* the whole strip is the pause control: click, tap, or focus+Enter/Space
    toggles it (WCAG 2.2.2). The button semantics are script-applied — static
    HTML must not promise behavior it can't deliver — and they come off under
    reduced motion, where nothing moves and there's nothing to pause.
    Descendants of role=button are presentational, so the sr-only vocabulary
    list lives outside as a sibling. */}
<div class="ticker">
  <div class="ticker-track" aria-hidden="true">
    {[0, 1].map(() => (
      <span class="ticker-run">
        {pairs.map(([eng, field]) => (
          <span class="pair">
            <span class="eng">{eng}</span>
            <span class="glyph">×</span>
            <span class="field">{field}</span>
          </span>
        ))}
      </span>
    ))}
  </div>
</div>
<div class="sr-only">
  <p>The vocabulary we speak, one engineering term paired with one field term.</p>
  <ul>
    {pairs.map(([eng, field]) => <li>{eng} and {field}</li>)}
  </ul>
</div>

<style>
  .ticker {
    position: relative;
    background: var(--void-deep);
    border-block: 1px solid var(--ink-faint);
    overflow: hidden; /* not clip: clipped marquee content must not feed doc scrollWidth */
    padding-block: 0.9rem;
  }

  .ticker[role='button'] { cursor: pointer; }

  /* the ring sits inside the strip — at the edges it would clip against
     the neighbouring bands */
  .ticker:focus-visible { outline-offset: -3px; }

  /* -- static by default, marquee only when JS runs -----------------
     The pause control is script-applied, so a page without JS must not
     move (WCAG 2.2.2 would have no pause). Base state: a centered wrapped
     grid of the first six pairs. html.js upgrades to the full marquee. */

  .ticker-track {
    display: flex;
    width: 100%;
  }

  .ticker-run {
    display: flex;
    flex: 1 1 auto;
    min-width: 0;
    flex-wrap: wrap;
    row-gap: 0.5rem;
    justify-content: center;
  }
  .ticker-run:last-child { display: none; }
  /* the static grid shows a taste, not the wall — six pairs */
  .ticker-run .pair:nth-child(n + 7) { display: none; }

  .pair {
    display: inline-flex;
    align-items: baseline;
    gap: 0.7em;
    padding-inline: 1.4em;
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    letter-spacing: 0.02em;
    /* long pairs break between terms, not against the strip edge */
    flex-wrap: wrap;
    justify-content: center;
    row-gap: 0.15rem;
  }

  html.js .ticker-track { width: max-content; }
  html.js .ticker-run {
    flex: 0 0 auto;
    flex-wrap: nowrap;
    /* duration tracks pair count: the animation covers the run's full width,
       so more pairs at a fixed duration = faster scroll */
    animation: slide 88s linear infinite;
  }
  html.js .ticker-run:last-child { display: flex; }
  html.js .ticker-run .pair:nth-child(n + 7) { display: inline-flex; }
  html.js .pair {
    white-space: nowrap;
    flex-wrap: nowrap;
  }

  .eng { color: var(--ink-dim); }
  .glyph { color: var(--acid); font-size: 0.85em; }
  .field { color: var(--ink); }

  @keyframes slide {
    to { translate: -100% 0; }
  }

  /* WCAG 2.2.2: moving content must be pausable — hover (real hover only:
     touch taps leave sticky emulated hover that blocks resume) or keyboard
     focus freezes it; a click, tap, or Enter/Space toggles .paused (script) */
  @media (hover: hover) {
    html.js .ticker:hover .ticker-run {
      animation-play-state: paused;
    }
  }
  html.js .ticker:focus-within .ticker-run,
  html.js .ticker.paused .ticker-run {
    animation-play-state: paused;
  }

  /* reduced motion returns to the base static grid even with JS */
  @media (prefers-reduced-motion: reduce) {
    .ticker { cursor: default; }
    html.js .ticker-track { width: 100%; }
    html.js .ticker-run {
      animation: none;
      flex: 1 1 auto;
      min-width: 0;
      flex-wrap: wrap;
    }
    html.js .ticker-run:last-child { display: none; }
    html.js .ticker-run .pair:nth-child(n + 7) { display: none; }
    html.js .pair {
      white-space: normal;
      flex-wrap: wrap;
    }
  }

</style>
<script>
  // the strip itself is the toggle: click/tap/Enter/Space pause and resume.
  // semantics are script-applied so a failed bundle never ships a dead
  // button, and they come off under reduced motion, where nothing moves.
  const ticker = document.querySelector<HTMLElement>('.ticker')!;
  const reduced = window.matchMedia('(prefers-reduced-motion: reduce)');

  const setSemantics = () => {
    if (reduced.matches) {
      ticker.classList.remove('paused');
      ticker.removeAttribute('role');
      ticker.removeAttribute('tabindex');
      ticker.removeAttribute('aria-pressed');
      ticker.removeAttribute('aria-label');
    } else {
      ticker.setAttribute('role', 'button');
      ticker.setAttribute('tabindex', '0');
      /* one state signal: the label stays put, aria-pressed carries it */
      ticker.setAttribute('aria-label', 'pause the vocabulary ticker');
      ticker.setAttribute('aria-pressed', String(ticker.classList.contains('paused')));
    }
  };
  setSemantics();
  reduced.addEventListener('change', setSemantics);

  const toggle = () => {
    const paused = ticker.classList.toggle('paused');
    ticker.setAttribute('aria-pressed', String(paused));
  };
  ticker.addEventListener('click', () => {
    if (reduced.matches) return;
    toggle();
  });
  ticker.addEventListener('keydown', (e) => {
    if (reduced.matches) return;
    if (e.key === 'Enter' || e.key === ' ') {
      e.preventDefault(); // Space must not scroll the page
      toggle();
    }
  });
</script>
