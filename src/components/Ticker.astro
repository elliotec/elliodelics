---
// Dual-fluency vocabulary: one engineering term, one field term, per pair.
const pairs = [
  ['code review', 'peer review'],
  ['data privacy', 'harm reduction'],
  ['audit trails', 'altered states'],
  ['observability', 'introspection'],
  ['GDPR', 'informed consent'],
  ['feature flags', 'titration'],
  ['role-based access', 'set & setting'],
  ['documentation', 'trip reports'],
  ['3rd-party integrations', 'integration circles'],
  ['SOC 2 security', 'trip sitting'],
  ['incident response', 'challenging experiences'],
  ['compliance', 'ceremony'],
  ['zero-downtime deploys', 'non-ordinary states'],
  ['data pipelines', 'dosing protocols'],
];
---

<div class="ticker">
  <div class="ticker-track" aria-hidden="true">
    {[0, 1].map(() => (
      <span class="ticker-run">
        {pairs.map(([eng, field]) => (
          <span class="pair">
            <span class="eng">{eng}</span>
            <span class="glyph">×</span>
            <span class="field">{field}</span>
          </span>
        ))}
      </span>
    ))}
  </div>
  <div class="sr-only">
    <p>The vocabulary we speak, one engineering term paired with one field term.</p>
    <ul>
      {pairs.map(([eng, field]) => <li>{eng} and {field}</li>)}
    </ul>
  </div>
</div>

<style>
  .ticker {
    position: relative;
    background: var(--void-deep);
    border-block: 1px solid var(--ink-faint);
    overflow: hidden; /* not clip: clipped marquee content must not feed doc scrollWidth */
    padding-block: 0.9rem;
  }

  .ticker-track {
    display: flex;
    width: max-content;
  }

  .ticker-run {
    display: flex;
    flex-shrink: 0;
    /* duration tracks pair count: the animation covers the run's full width,
       so more pairs at a fixed duration = faster scroll */
    animation: slide 88s linear infinite;
  }

  .pair {
    display: inline-flex;
    align-items: baseline;
    gap: 0.7em;
    padding-inline: 1.4em;
    white-space: nowrap;
    font-family: var(--font-mono);
    font-size: var(--text-mono);
    letter-spacing: 0.02em;
  }

  .eng { color: var(--ink-dim); }
  .glyph { color: var(--acid); font-size: 0.85em; }
  .field { color: var(--ink); }

  @keyframes slide {
    to { translate: -100% 0; }
  }

  /* WCAG 2.2.2: moving content must be pausable — hover (real hover only:
     touch taps leave sticky emulated hover that blocks resume) or keyboard
     focus freezes it; on touch, a tap toggles .paused (see script) */
  @media (hover: hover) {
    .ticker:hover .ticker-run {
      animation-play-state: paused;
    }
  }
  .ticker:focus-within .ticker-run,
  .ticker.paused .ticker-run {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .ticker-track { width: 100%; }
    .ticker-run {
      animation: none;
      flex: 1 1 auto;   /* release flex-shrink:0 so wrapping can engage */
      min-width: 0;
      flex-wrap: wrap;
      row-gap: 0.5rem;
      justify-content: center;
    }
    .ticker-run:last-child { display: none; }
  }

</style>
<script>
  // touch has no hover: a tap toggles the marquee instead. click (not
  // pointerdown) so scroll flicks across the strip never trigger it.
  const ticker = document.querySelector('.ticker')!;
  let lastPointerType = '';
  ticker.addEventListener(
    'pointerdown',
    (e) => { lastPointerType = (e as PointerEvent).pointerType; },
    { passive: true }
  );
  ticker.addEventListener('click', () => {
    if (lastPointerType === 'touch') ticker.classList.toggle('paused');
  });
</script>
