---
---

{/* outside <main> and any section so it maps to the contentinfo landmark;
    visually it stays part of the abyss band */}
<footer class="footer">
  <div class="container inner">
    <p class="mono">elliodelics © {new Date().getFullYear()}</p>
    <p class="mono dim">software engineering for the psychedelic industry</p>
    <p class="mono dim">no cookies, no trackers</p>
  </div>
  {/* the proof pages, promoted from shy footer links to a labeled index —
      the receipts a compliance-minded visitor came to check */}
  <nav class="container records mono" aria-label="on the record">
    <p class="records-title dim">on the record</p>
    <ul>
      <li><a href="/accessibility">accessibility</a><span class="dim"> · built to WCAG 2.2 AAA, with the evidence</span></li>
      <li><a href="/privacy">privacy</a><span class="dim"> · what happens with your data, which is almost nothing</span></li>
      <li><a href="/vocabulary">vocabulary</a><span class="dim"> · every term from the ticker, defined</span></li>
      <li><a href="/plain">plain words</a><span class="dim"> · the whole site in simple language</span></li>
      <li><a href="/colophon">colophon</a><span class="dim"> · how this page is built</span></li>
    </ul>
  </nav>
</footer>

<style>
  .footer {
    background: var(--void-abyss);
  }

  .inner {
    padding-block: clamp(3rem, 8vh, 5rem) 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 2.5rem;
    justify-content: space-between;
  }

  .inner p { margin: 0; }
  .dim { color: var(--ink-dim); }

  .records {
    padding-block: 1.6rem 2rem;
    margin-block-start: 2.2rem;
  }

  .records-title {
    margin: 0 0 1rem;
    padding-block-start: 1.2rem;
    border-block-start: 1px solid var(--ink-faint);
  }

  .records ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(19rem, 1fr));
    gap: 0.7rem 2.5rem;
  }

  .records a {
    color: var(--acid);
    text-decoration: none;
    /* ≥44px target without moving the lines */
    padding-block: 1em;
    margin-block: -1em;
    display: inline-block;
  }
  .records a:hover { text-decoration: underline; }
</style>
